{
  "policies": {
    "AppAutoUpdate": true,
    "DisableFirefoxStudies": true,
    "DisableTelemetry": true,
    "DisableFeedbackCommands": true,
    "DisableSetDesktopBackground": false,
    "DisableDeveloperTools": false,
    "DontCheckDefaultBrowser": true,
    "DisableBuiltinPDFViewer": false,
    "PasswordManagerEnabled": false,
    
    "FirefoxHome": {
      "Search": false,
      "TopSites": false,
      "SponsoredTopSites": false,
      "Pocket": false,
      "SponsoredPocket": false,
      "Highlights": false,
      "Snippets": false,
      "Locked": true
    },
    
    "GenerativeAI": {
      "Enabled": false
    },
    
    "ManualAppUpdateOnly": false,
    "NoDefaultBookmarks": true,
    
    "EnableTrackingProtection": {
      "Value": true,
      "Locked": true,
      "Cryptomining": true,
      "Fingerprinting": true,
      "EmailTracking": true
    },
    
    "Cookies": {
      "Behavior": "reject-tracker",
      "BehaviorPrivateBrowsing": "reject-tracker",
      "Locked": true
    },
    
    "Permissions": {
      "Autoplay": {
        "Allow": [],
        "Block": [],
        "Default": "block-audio-video",
        "Locked": true
      }
    },
    
    "Preferences": {
      "webgl.disabled": {
        "Value": false,
        "Status": "locked"
      },
      "media.peerconnection.enabled": {
        "Value": true,
        "Status": "locked"
      },
      "privacy.fingerprintingProtection": {
        "Value": true,
        "Status": "locked"
      },
      "privacy.fingerprintingProtection.pbmode": {
        "Value": true,
        "Status": "locked"
      },
      "privacy.fingerprintingProtection.overrides": {
        "Value": "+FontVisibilityLevel2,-CanvasExtraction,-ScreenFingerprinting,-KeyboardFingerprinting,-AudioFingerprinting",
        "Status": "locked"
      },
      "privacy.fingerprintingProtection.granularOverrides": {
        "Value": true,
        "Status": "locked"
      },
      "browser.safebrowsing.phishing.enabled": {
        "Value": true,
        "Status": "locked"
      },
      "browser.safebrowsing.malware.enabled": {
        "Value": true,
        "Status": "locked"
      },
      "dom.security.https_only_mode": {
        "Value": true,
        "Status": "locked"
      },
      "network.http.referer.XOriginTrimmingPolicy": {
        "Value": 2,
        "Status": "locked"
      },
      "browser.translations.enable": {
        "Value": true,
        "Status": "locked"
      },
      "browser.translations.automaticallyPopup": {
        "Value": true,
        "Status": "locked"
      },
      "network.cookie.cookieBehavior": {
        "Value": 5,
        "Status": "locked"
      },
      "network.cookie.cookieBehavior.pbmode": {
        "Value": 5,
        "Status": "locked"
      },
      "dom.event.clipboardevents.enabled": {
        "Value": true,
        "Status": "locked"
      },
      "dom.events.asyncClipboard.dataTransfer": {
        "Value": true,
        "Status": "locked"
      }
    },
    
    "Extensions": {
      "Install": [
        "https://addons.mozilla.org/firefox/downloads/latest/ublock-origin/latest.xpi"
      ],
      "Uninstall": [
        "amazondotcom@search.mozilla.org",
        "ebay@search.mozilla.org",
        "bing@search.mozilla.org",
        "google@search.mozilla.org"
      ],
      "ExtensionSettings": {
        "uBlock0@raymondhill.net": {
          "installation_mode": "force_installed",
          "install_url": "https://addons.mozilla.org/firefox/downloads/latest/ublock-origin/latest.xpi",
          "locked": true
        }
      }
    },
    
    "SearchEngines": {
      "PreventInstalls": true,
      "Remove": [
        "Amazon.com",
        "Bing",
        "eBay",
        "MercadoLivre",
        "Perplexity",
        "Google",
        "Twitter"
      ],
      "Default": "DuckDuckGo",
      "Add": [
        {
          "Name": "DuckDuckGo Lite",
          "Description": "Versão minimalista e sem anúncios do DuckDuckGo",
          "Alias": "ddgl",
          "Method": "POST",
          "URLTemplate": "https://duckduckgo.com/lite/?q={searchTerms}",
          "PostData": "q={searchTerms}",
          "IconURL": "https://duckduckgo.com/favicon.ico"
        },
        {
          "Name": "SearXNG",
          "Description": "Mecanismo de busca meta que respeita a privacidade",
          "Alias": "sxng",
          "Method": "POST",
          "URLTemplate": "https://searx.be/?q={searchTerms}",
          "PostData": "q={searchTerms}&time_range=&language=pt-BR&category_general=on",
          "IconURL": "https://searx.be/favicon.ico"
        },
        {
          "Name": "StartPage",
          "Description": "Resultados do Google sem rastreamento",
          "Alias": "startpage",
          "Method": "GET",
          "URLTemplate": "https://www.startpage.com/sp/search?query={searchTerms}",
          "IconURL": "https://www.startpage.com/sp/cdn/favicons/favicon--light.ico"
        }
      ]
    }
  }
}